# Determine dotfiles directory dynamically (works even when symlinked)
DOTFILES_DIR="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")"

alias more='less'
alias cat='batcat'
alias c='cursor'
alias squash='git commit --amend --no-edit'
alias resource='echo "Reloading bashrc" && source ~/.bashrc'
alias sshdev='ssh ec2'
alias ca="$DOTFILES_DIR/scripts/cursor-agent-wrapper.sh"
alias gl='git lg'
alias o='xdg-open'

# GitHub shortcuts
alias gb='gh browse -b $(git branch --show-current)'   # Open current repo on GitHub at current branch
alias ghb='gh browse -b $(git branch --show-current)'  # Open current branch on GitHub
alias ghpr='gh pr view --web'                          # Open PR for current branch
alias ghprs='gh pr list --web'                         # Open all PRs for this repo
alias ghc='gh browse -c'                               # Open recent commits
alias ghlc='gh browse $(git rev-parse HEAD)'           # Open last commit on GitHub
alias ghr='gh repo view --web'                         # Open repo home on GitHub

alias godell='ssh dell'
alias goasus='ssh asus'
alias goresearcher='cd ~/dev/researcher'
alias godebugger='cd ~/dev/debugger'
alias ld=lazydocker

alias ec2instance='aws ec2 describe-instances --filters "Name=tag:Name,Values=DevJun2025" --query "Reservations[].Instances[].InstanceId" --output text'
alias ec2start='aws ec2 start-instances --instance-ids $(ec2instance)'
alias ec2stop='aws ec2 stop-instances --instance-ids $(ec2instance)'

avi_to_mp4() {
    local input="$1"

    if [[ -z "$input" ]]; then
        echo "Usage: avi_to_mp4 file.avi"
        return 1
    fi

    if [[ ! -f "$input" ]]; then
        echo "File not found: $input"
        return 1
    fi

    local output="${input%.avi}.mp4"

    ffmpeg -i "$input" -c:v libx264 -c:a aac "$output"
}

